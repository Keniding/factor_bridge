# =========================================================
# Modo: Google AI Studio (recomendado para desarrollo)
# Obtén tu key gratis: https://aistudio.google.com/app/apikey
# =========================================================
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=tu_api_key_de_google_ai_studio_aqui

# =========================================================
# Modo: Vertex AI (producción en GCP) -- alternativa
# Comenta las dos líneas anteriores y descomenta estas
# =========================================================
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=tu-proyecto-gcp
# GOOGLE_CLOUD_LOCATION=us-central1

# =========================================================
# APIs externas Perú (opcionales - el agente funciona con mocks si faltan)
# =========================================================
# Token gratuito: https://apis.net.pe
APIS_NET_PE_TOKEN=

# Token: https://api.decolecta.com
DECOLECTA_TOKEN=
